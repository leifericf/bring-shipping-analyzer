<ul class="breadcrumb">
  <li><a href="/">Dashboard</a></li>
  <% if (editing) { %>
    <li><a href="/accounts/<%= account.id %>/runs"><%= account.name %></a></li>
    <li>Edit</li>
  <% } else { %>
    <li>New Account</li>
  <% } %>
</ul>

<h1><%= editing ? 'Edit Account' : 'New Account' %></h1>

<form method="POST" action="<%= editing ? '/accounts/' + account.id : '/accounts' %>">
  <label>
    Account Name
    <input type="text" name="name" value="<%= account.name || '' %>" placeholder="e.g. My Store" required>
  </label>

  <fieldset>
    <legend>API Credentials</legend>

    <label>
      API User ID (email)
      <input type="email" name="api_uid" value="<%= account.api_uid || '' %>" placeholder="your-email@example.com" required>
    </label>

    <label>
      API Key
      <input type="text" name="api_key" value="<%= account.api_key || '' %>" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" required>
    </label>

    <div class="grid">
      <label>
        Customer Number
        <input type="text" name="customer_number" value="<%= account.customer_number || '' %>" placeholder="e.g. XXXXXXXXXXXXX" required>
      </label>

      <label>
        Origin Postal Code
        <input type="text" name="origin_postal_code" value="<%= account.origin_postal_code || '0174' %>" placeholder="e.g. 0001" required>
      </label>
    </div>
  </fieldset>

  <div class="form-actions">
    <button type="submit"><%= editing ? 'Save Changes' : 'Create Account' %></button>
    <a href="<%= editing ? '/accounts/' + account.id + '/runs' : '/' %>" role="button" class="outline secondary">Cancel</a>
  </div>
</form>

<% if (editing) { %>
  <details class="danger-zone">
    <summary><h3>Delete account</h3></summary>
    <p>Permanently delete <strong><%= account.name %></strong> and all associated runs, rates, and invoices.</p>
    <form method="POST" action="/accounts/<%= account.id %>/delete"
          onsubmit="return confirm('Delete this account and all its data? This cannot be undone.')">
      <div class="form-actions">
        <button type="submit" class="outline btn-danger">Delete Account</button>
      </div>
    </form>
  </details>
<% } %>
