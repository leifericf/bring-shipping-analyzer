<h1>Dashboard</h1>

<section>
  <hgroup>
    <h2>Accounts</h2>
    <p><%= accounts.length %> account<%= accounts.length !== 1 ? 's' : '' %> configured</p>
  </hgroup>

  <% if (accounts.length === 0) { %>
    <div class="empty-state">
      <% if (demoMode) { %>
        <div class="empty-icon">&#x1f4f7;</div>
        <p>No accounts marked for demo mode.</p>
        <p>Exit demo mode and mark accounts with "Include in demo".</p>
      <% } else { %>
        <div class="empty-icon">&#x1f4e6;</div>
        <p>No accounts yet.</p>
        <a href="/accounts/new" role="button">Create your first account</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="account-grid">
      <% for (const account of accounts) { %>
        <article class="account-card">
          <a href="/accounts/<%= account.id %>/runs" class="account-card-link">
            <strong class="account-card-name"><%= account.name %></strong>
            <span class="account-card-meta"><code><%= account.customer_number %></code> · <%= account.origin_postal_code %></span>
          </a>
          <footer class="account-card-footer">
            <a href="/accounts/<%= account.id %>/config">Config</a>
            <a href="/accounts/<%= account.id %>/edit">Edit</a>
          </footer>
        </article>
      <% } %>
    </div>
  <% } %>
</section>

<section>
  <hgroup>
    <h2>Recent Runs</h2>
    <p>Latest pipeline runs across all accounts</p>
  </hgroup>

  <% if (recentRuns.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">&#x1f680;</div>
      <p>No runs yet.</p>
      <p>Start a run from an account page.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Run</th>
            <th>Account</th>
            <th>Customer</th>
            <th>Date</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% for (const run of recentRuns) { %>
            <tr>
              <td><a href="/runs/<%= run.id %>">#<%= run.id %></a></td>
              <td>
                <% if (run.account_id) { %>
                  <a href="/accounts/<%= run.account_id %>/runs"><%= run.account_name %></a>
                <% } else { %>
                  <span class="muted">(CLI)</span>
                <% } %>
              </td>
              <td><code><%= run.customer_number %></code></td>
              <td><%= fmtDate(run.created_at) %></td>
              <td><span class="status status-<%= run.status %>"><%= fmtStatus(run.status) %></span></td>
              <td><a href="/runs/<%= run.id %>">View</a></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
