<ul class="breadcrumb">
  <li><a href="/">Dashboard</a></li>
  <li><a href="/accounts/<%= account.id %>/runs"><%= account.name %></a></li>
  <li>Config</li>
</ul>

<hgroup>
  <h1>Configuration</h1>
  <p><%= account.name %> &mdash; shipping countries, services, weight tiers, and analysis settings.</p>
</hgroup>

<div id="flagged-warning-container">
  <!-- Rebuilt dynamically by renderFlaggedWarning() -->
</div>

<form method="POST" action="/accounts/<%= account.id %>/config" id="config-form">

  <!-- ------------------------------------------------------------------ -->
  <!-- Destinations UI                                                     -->
  <!-- ------------------------------------------------------------------ -->

  <section id="destinations-section">
    <h2>Shipping Countries <span id="dest-count" class="dest-count"></span></h2>
    <p>Countries your store ships to. Each country needs a name, ISO code, and representative postal code for rate lookups.</p>

    <!-- Add controls — prominent, above the list -->
    <div class="add-country-controls">
      <div class="add-country-tabs" role="tablist">
        <button type="button" class="add-tab active" data-panel="add-single-panel" role="tab" aria-selected="true">Single country</button>
        <button type="button" class="add-tab" data-panel="add-region-panel" role="tab" aria-selected="false">By region</button>
      </div>

      <!-- Single country -->
      <div id="add-single-panel" class="add-panel active" role="tabpanel">
        <div class="add-country-search">
          <div class="autocomplete-wrap" role="combobox" aria-expanded="false" aria-haspopup="listbox" aria-owns="country-suggestions">
            <input type="text" id="new-country" placeholder="Type a country name to add it..." autocomplete="off" aria-autocomplete="list" aria-controls="country-suggestions" aria-label="Country name">
            <ul class="autocomplete-list" id="country-suggestions" role="listbox" aria-label="Country suggestions"></ul>
          </div>
        </div>
        <div class="dest-add-error" id="dest-add-error"></div>
        <details class="add-country-advanced">
          <summary>Advanced: manual entry</summary>
          <p class="region-help">Add a country manually if it is not in the autocomplete list.</p>
          <div class="add-country-row">
            <input type="text" id="new-code" placeholder="Code (SE)" maxlength="2" aria-label="Country code" class="add-country-code">
            <input type="text" id="new-postal" placeholder="Postal code" aria-label="Postal code" class="add-country-postal">
            <input type="number" id="new-zone" placeholder="Zone" min="1" aria-label="Zone" class="add-country-zone">
            <input type="text" id="new-desc" placeholder="Description" aria-label="Description" class="add-country-desc">
            <button type="button" id="add-dest-btn">Add</button>
          </div>
        </details>
      </div>

      <!-- By region -->
      <div id="add-region-panel" class="add-panel" role="tabpanel">
        <p class="region-help">
          Select a region to add all its countries. Uses the capital city as a postal code placeholder.
          Countries already in your list will be skipped.
        </p>
        <div class="region-picker">
          <label>
            Region
            <select id="region-select">
              <option value="">Choose a region...</option>
              <optgroup label="Europe">
                <option value="Northern Europe">Northern Europe</option>
                <option value="Western Europe">Western Europe</option>
                <option value="Central Europe">Central Europe</option>
                <option value="Southern Europe">Southern Europe</option>
                <option value="Southeast Europe">Southeast Europe</option>
                <option value="Eastern Europe">Eastern Europe</option>
              </optgroup>
              <optgroup label="Other regions">
                <option value="North America">North America</option>
                <option value="South America">South America</option>
                <option value="Central America">Central America</option>
                <option value="Caribbean">Caribbean</option>
                <option value="Northern Africa">Northern Africa</option>
                <option value="Western Africa">Western Africa</option>
                <option value="Eastern Africa">Eastern Africa</option>
                <option value="Southern Africa">Southern Africa</option>
                <option value="Middle Africa">Middle Africa</option>
                <option value="Western Asia">Western Asia</option>
                <option value="Central Asia">Central Asia</option>
                <option value="Southern Asia">Southern Asia</option>
                <option value="South-Eastern Asia">South-Eastern Asia</option>
                <option value="Eastern Asia">Eastern Asia</option>
                <option value="Australia and New Zealand">Australia and New Zealand</option>
                <option value="Melanesia">Melanesia</option>
                <option value="Micronesia">Micronesia</option>
                <option value="Polynesia">Polynesia</option>
              </optgroup>
            </select>
          </label>
        </div>
        <div id="region-preview" class="region-preview" style="display:none;">
          <p id="region-preview-label"></p>
          <div class="region-country-list" id="region-country-list"></div>
          <div class="dest-add-actions">
            <button type="button" id="add-region-btn">Add selected countries</button>
          </div>
        </div>
        <div id="region-loading" style="display:none;" aria-busy="true">Loading countries...</div>
        <div class="dest-add-error" id="region-error"></div>
      </div>
    </div>

    <!-- Country list -->
    <div id="dest-groups">
      <!-- filled by JS: one <details> per region -->
    </div>

  </section>

  <!-- ------------------------------------------------------------------ -->
  <!-- Analysis settings                                                   -->
  <!-- ------------------------------------------------------------------ -->

  <section id="analysis-section">
    <h2>Analysis Settings</h2>

    <label>
      <input type="checkbox" id="vat-inclusive" role="switch">
      Include VAT in domestic prices
    </label>
    <p class="help-text">
      When enabled, domestic (Norway) customer-facing rates include 25% VAT. Disable for B2B pricing where customers handle VAT themselves.
    </p>

    <label>
      International zone merge threshold
      <div class="threshold-control">
        <input type="range" id="merge-threshold" min="0" max="50" step="1" value="10">
        <output id="merge-threshold-value">10%</output>
      </div>
    </label>
    <p class="help-text">
      Countries with rates within this percentage of each other are merged into one shipping zone.
      Lower = more zones (stricter). Higher = fewer zones (more merging). Default: 10%.
    </p>
  </section>

  <!-- ------------------------------------------------------------------ -->
  <!-- Raw JSON editor (advanced)                                          -->
  <!-- ------------------------------------------------------------------ -->

  <details class="mt-2">
    <summary>Advanced: Raw JSON editor</summary>
    <p>
      Edit the full JSON configuration directly. Changes here override the country list above.
    </p>
    <textarea name="config" class="config-editor" id="config-editor" spellcheck="false"><%= configJson %></textarea>
    <div class="config-error" id="config-error"></div>
    <div class="form-actions bt-0">
      <button type="button" class="outline secondary" onclick="formatJson()">Format JSON</button>
      <button type="button" class="outline secondary" onclick="syncTableFromEditor()">Reload table from JSON</button>
    </div>
  </details>

  <!-- ------------------------------------------------------------------ -->
  <!-- Demo mode                                                           -->
  <!-- ------------------------------------------------------------------ -->

  <section>
    <h2>Demo Mode</h2>
    <form method="POST" action="/accounts/<%= account.id %>/<%= account.is_demo_account ? 'unmark-demo' : 'mark-demo' %>" class="demo-config-form">
      <label>
        <input type="checkbox" role="switch" onchange="this.form.submit()" <%= account.is_demo_account ? 'checked' : '' %>>
        Include this account in demo mode
      </label>
    </form>
    <p class="help-text">
      When demo mode is active, only accounts with this setting enabled are shown on the dashboard.
    </p>
  </section>

  <div class="form-actions">
    <button type="submit">Save Configuration</button>
    <a href="/accounts/<%= account.id %>/runs" class="secondary">Back to Runs</a>
  </div>
</form>

<script>
// ---------------------------------------------------------------------------
// Flagged countries (injected from server)
// ---------------------------------------------------------------------------

const FLAGGED = new Map(<%- JSON.stringify((typeof flaggedCountries !== 'undefined' ? flaggedCountries : []).map(f => [f.code, f])) %>);
const RISK_LABELS = <%- JSON.stringify(typeof riskLabels !== 'undefined' ? riskLabels : {}) %>;
const RISK_CLASSES = { critical: 'risk-critical', high: 'risk-high', medium: 'risk-medium', low: 'risk-low' };

function getFlagged(code) { return FLAGGED.get(code) || null; }

// ---------------------------------------------------------------------------
// Country data from REST Countries API
// ---------------------------------------------------------------------------

let allCountries = []; // { name, code, capital, subregion, region }

async function loadCountries() {
  try {
    const resp = await fetch('https://restcountries.com/v3.1/all?fields=name,cca2,capital,subregion,region');
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const data = await resp.json();
    allCountries = data
      .map(c => ({
        name: c.name.common,
        code: c.cca2,
        capital: (c.capital && c.capital[0]) || '',
        subregion: c.subregion || '',
        region: c.region || '',
      }))
      .sort((a, b) => a.name.localeCompare(b.name));
  } catch (err) {
    console.warn('Could not load country list from restcountries.com:', err.message);
  }
}

// Fire on page load — re-render destinations once we have region data
loadCountries().then(() => renderDestinations());

// ---------------------------------------------------------------------------
// Flagged country warning banner (dynamic)
// ---------------------------------------------------------------------------

function renderFlaggedWarning() {
  const container = document.getElementById('flagged-warning-container');
  const config = getConfig();
  if (!config || !Array.isArray(config.destinations)) {
    container.innerHTML = '';
    return;
  }

  const flagged = config.destinations
    .map(d => getFlagged(d.code))
    .filter(Boolean)
    .sort((a, b) => RISK_LEVELS.indexOf(a.risk) - RISK_LEVELS.indexOf(b.risk));

  if (flagged.length === 0) {
    container.innerHTML = '';
    return;
  }

  const label = flagged.length === 1 ? '1 flagged country' : flagged.length + ' flagged countries';
  const rows = flagged.map(f =>
    '<tr class="flagged-' + f.risk + '">' +
    '<td><strong>' + esc(f.country) + '</strong> (<code>' + esc(f.code) + '</code>)</td>' +
    '<td><span class="risk-badge ' + RISK_CLASSES[f.risk] + '">' + esc(RISK_LABELS[f.risk]) + '</span></td>' +
    '<td>' + esc(f.reason) + '</td>' +
    '</tr>'
  ).join('');

  container.innerHTML =
    '<details class="flagged-warning" open>' +
    '<summary>Warning: ' + label + ' in shipping countries</summary>' +
    '<table class="flagged-table"><thead><tr><th>Country</th><th>Risk</th><th>Reason</th></tr></thead>' +
    '<tbody>' + rows + '</tbody></table>' +
    '</details>';
}

const RISK_LEVELS = ['critical', 'high', 'medium', 'low'];

// ---------------------------------------------------------------------------
// State helpers
// ---------------------------------------------------------------------------

function getConfig() {
  try {
    return JSON.parse(document.getElementById('config-editor').value);
  } catch { return null; }
}

function setConfig(config) {
  document.getElementById('config-editor').value = JSON.stringify(config, null, 2);
}

// ---------------------------------------------------------------------------
// Render destinations grouped by region
// ---------------------------------------------------------------------------

// Look up the subregion for a country code using the API data
function getSubregion(code) {
  const c = allCountries.find(x => x.code === code);
  return c ? c.subregion : '';
}

function renderDestinations() {
  renderFlaggedWarning();
  const config = getConfig();
  if (!config || !Array.isArray(config.destinations)) return;

  // Update destination count badge
  const countEl = document.getElementById('dest-count');
  if (countEl) countEl.textContent = '(' + config.destinations.length + ')';

  const container = document.getElementById('dest-groups');

  // Remember which details are currently open so we can preserve state
  const openRegions = new Set();
  container.querySelectorAll('details[open]').forEach(d => {
    openRegions.add(d.dataset.region);
  });

  container.innerHTML = '';

  // Group destinations by region, keeping original array index for remove
  const originCountry = config.originCountry || '';
  const groups = {};
  config.destinations.forEach((d, i) => {
    let region;
    if (d.code === originCountry) {
      region = 'Domestic';
    } else if (allCountries.length > 0) {
      region = getSubregion(d.code) || 'Other';
    } else {
      region = 'All countries';
    }
    if (!groups[region]) groups[region] = [];
    groups[region].push({ dest: d, index: i });
  });

  // Sort region names: Domestic first, then alphabetical, "Other" last
  const regionNames = Object.keys(groups).sort((a, b) => {
    if (a === 'Domestic') return -1;
    if (b === 'Domestic') return 1;
    if (a === 'Other') return 1;
    if (b === 'Other') return -1;
    if (a === 'All destinations') return 0;
    return a.localeCompare(b);
  });

  regionNames.forEach(region => {
    const items = groups[region];
    const details = document.createElement('details');
    details.dataset.region = region;
    // Open by default on first render, or preserve previous open state
    details.open = openRegions.size === 0 || openRegions.has(region);

    const summary = document.createElement('summary');
    summary.innerHTML = esc(region) + ' <span class="dest-count">(' + items.length + ')</span>';
    details.appendChild(summary);

    const wrap = document.createElement('div');
    wrap.className = 'table-wrap';

    const table = document.createElement('table');
    table.innerHTML =
      '<thead><tr>' +
      '<th>Country</th><th>Code</th><th>Postal Code</th><th>Zone</th><th>Description</th><th></th>' +
      '</tr></thead>';

    const tbody = document.createElement('tbody');
    items.forEach(({ dest: d, index: i }) => {
      const flag = getFlagged(d.code);
      const tr = document.createElement('tr');
      if (flag) tr.className = 'flagged-row flagged-' + flag.risk;
      const flagBadge = flag
        ? ' <span class="risk-badge ' + RISK_CLASSES[flag.risk] + '" title="' + esc(flag.reason) + '">' + esc(RISK_LABELS[flag.risk]) + '</span>'
        : '';
      tr.innerHTML =
        '<td>' + esc(d.country) + flagBadge + '</td>' +
        '<td><code>' + esc(d.code) + '</code></td>' +
        '<td>' + esc(d.postalCode) + '</td>' +
        '<td>' + (d.zone != null ? esc(String(d.zone)) : '<span class="muted">\u2014</span>') + '</td>' +
        '<td>' + (flag ? '<span class="flagged-reason">' + esc(flag.reason) + '</span>' : (d.desc ? esc(d.desc) : '')) + '</td>' +
        '<td><button type="button" class="outline secondary dest-remove-btn" data-index="' + i + '">Remove</button></td>';
      tbody.appendChild(tr);
    });
    table.appendChild(tbody);
    wrap.appendChild(table);
    details.appendChild(wrap);
    container.appendChild(details);
  });

  // Bind remove buttons
  container.querySelectorAll('.dest-remove-btn').forEach(btn => {
    btn.addEventListener('click', function () {
      removeDest(Number(this.dataset.index));
    });
  });
}

function esc(s) {
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

// ---------------------------------------------------------------------------
// Autocomplete for country name
// ---------------------------------------------------------------------------

(function () {
  const input = document.getElementById('new-country');
  const list = document.getElementById('country-suggestions');
  const combobox = input.closest('[role="combobox"]');
  let activeIdx = -1;

  function setExpanded(open) {
    list.style.display = open ? 'block' : 'none';
    combobox.setAttribute('aria-expanded', String(open));
    if (!open) {
      input.removeAttribute('aria-activedescendant');
    }
  }

  input.addEventListener('input', function () {
    const val = this.value.trim().toLowerCase();
    list.innerHTML = '';
    activeIdx = -1;
    if (!val || val.length < 1 || allCountries.length === 0) {
      setExpanded(false);
      return;
    }
    // Match countries: starts-with first, then contains
    const starts = allCountries.filter(c => c.name.toLowerCase().startsWith(val));
    const contains = allCountries.filter(c =>
      !c.name.toLowerCase().startsWith(val) && c.name.toLowerCase().includes(val)
    );
    const matches = starts.concat(contains).slice(0, 12);
    if (matches.length === 0) {
      setExpanded(false);
      return;
    }
    matches.forEach((c, i) => {
      const li = document.createElement('li');
      li.id = 'country-opt-' + i;
      li.setAttribute('role', 'option');
      const flag = getFlagged(c.code);
      const badge = flag
        ? ' <span class="risk-badge ' + RISK_CLASSES[flag.risk] + '">' + esc(RISK_LABELS[flag.risk]) + '</span>'
        : '';
      li.innerHTML = esc(c.name) + ' <code>' + esc(c.code) + '</code>' + badge;
      li.dataset.index = i;
      li.addEventListener('mousedown', function (e) {
        e.preventDefault(); // prevent blur before click fires
        selectCountry(c);
      });
      list.appendChild(li);
    });
    setExpanded(true);
  });

  input.addEventListener('keydown', function (e) {
    const items = list.querySelectorAll('[role="option"]');
    if (!items.length) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIdx = Math.min(activeIdx + 1, items.length - 1);
      highlightItem(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIdx = Math.max(activeIdx - 1, 0);
      highlightItem(items);
    } else if (e.key === 'Enter' && activeIdx >= 0) {
      e.preventDefault();
      items[activeIdx].dispatchEvent(new Event('mousedown'));
    } else if (e.key === 'Escape') {
      setExpanded(false);
      activeIdx = -1;
    }
  });

  function highlightItem(items) {
    items.forEach((li, i) => {
      const isActive = i === activeIdx;
      li.classList.toggle('active', isActive);
      li.setAttribute('aria-selected', String(isActive));
      if (isActive) {
        li.scrollIntoView({ block: 'nearest' });
        input.setAttribute('aria-activedescendant', li.id);
      }
    });
  }

  input.addEventListener('blur', function () {
    // Small delay so mousedown on list items can fire first
    setTimeout(() => { setExpanded(false); }, 150);
  });

  function selectCountry(c) {
    setExpanded(false);
    activeIdx = -1;
    input.value = '';

    // Auto-add using sensible defaults from the API
    const code = c.code;
    const country = c.name;
    const postal = c.capital || '00000';
    const desc = c.capital || null;

    const errorEl = document.getElementById('dest-add-error');
    errorEl.style.display = 'none';

    // Warn if flagged
    const flag = getFlagged(code);
    if (flag) {
      const riskLabel = RISK_LABELS[flag.risk] || flag.risk;
      if (!confirm('Warning: ' + country + ' (' + code + ') is flagged as ' + riskLabel + ' risk.\n\n' + flag.reason + '\n\nAre you sure you want to add it?')) {
        return;
      }
    }

    const config = getConfig();
    if (!config) {
      errorEl.textContent = 'Cannot add \u2014 underlying JSON is invalid.';
      errorEl.style.display = 'block';
      return;
    }
    if (!Array.isArray(config.destinations)) config.destinations = [];

    // Check for duplicate
    if (config.destinations.find(d => d.code === code)) {
      errorEl.textContent = country + ' (' + code + ') is already in the list.';
      errorEl.style.display = 'block';
      return;
    }

    const entry = { country, code, postalCode: postal };
    if (desc) entry.desc = desc;

    config.destinations.push(entry);
    setConfig(config);
    renderDestinations();

    // Brief success feedback
    input.placeholder = 'Added ' + country;
    setTimeout(() => { input.placeholder = 'Type a country name to add it...'; }, 1500);
  }
})();

// ---------------------------------------------------------------------------
// Region-based bulk add
// ---------------------------------------------------------------------------

document.getElementById('region-select').addEventListener('change', function () {
  const subregion = this.value;
  const preview = document.getElementById('region-preview');
  const loading = document.getElementById('region-loading');
  const errorEl = document.getElementById('region-error');
  errorEl.style.display = 'none';

  if (!subregion) {
    preview.style.display = 'none';
    return;
  }

  if (allCountries.length === 0) {
    loading.style.display = 'block';
    preview.style.display = 'none';
    // Retry loading, then re-trigger
    loadCountries().then(() => {
      loading.style.display = 'none';
      if (allCountries.length === 0) {
        errorEl.textContent = 'Could not load country data from restcountries.com. Check your connection.';
        errorEl.style.display = 'block';
      } else {
        this.dispatchEvent(new Event('change'));
      }
    });
    return;
  }

  const config = getConfig();
  const existingCodes = new Set(
    config && Array.isArray(config.destinations)
      ? config.destinations.map(d => d.code)
      : []
  );

  const regionCountries = allCountries
    .filter(c => c.subregion === subregion)
    .sort((a, b) => a.name.localeCompare(b.name));

  if (regionCountries.length === 0) {
    errorEl.textContent = 'No countries found for "' + subregion + '".';
    errorEl.style.display = 'block';
    preview.style.display = 'none';
    return;
  }

  const listEl = document.getElementById('region-country-list');
  listEl.innerHTML = '';

  regionCountries.forEach(c => {
    const already = existingCodes.has(c.code);
    const flag = getFlagged(c.code);
    const isFlagged = !!flag;
    const label = document.createElement('label');
    label.className = 'region-country-item' + (already ? ' already-added' : '') + (isFlagged ? ' flagged-item' : '');

    // Uncheck medium/high/critical risk; low risk and unflagged stay checked
    const isElevatedRisk = isFlagged && flag.risk !== 'low';
    const checked = already ? '' : (isElevatedRisk ? '' : 'checked');
    const disabled = already ? 'disabled' : '';

    let flagHtml = '';
    if (isFlagged) {
      flagHtml = ' <span class="risk-badge ' + RISK_CLASSES[flag.risk] + '">' + esc(RISK_LABELS[flag.risk]) + '</span>' +
        ' <small class="flagged-reason">' + esc(flag.reason) + '</small>';
    }

    label.innerHTML =
      '<input type="checkbox" ' + checked + ' ' + disabled + ' value="' + esc(c.code) + '">' +
      ' ' + esc(c.name) + ' <code>' + esc(c.code) + '</code>' +
      (c.capital ? ' <small class="muted">' + esc(c.capital) + '</small>' : '') +
      (already ? ' <small class="muted">(already added)</small>' : '') +
      flagHtml;
    listEl.appendChild(label);
  });

  const newCount = regionCountries.filter(c => !existingCodes.has(c.code)).length;
  document.getElementById('region-preview-label').textContent =
    subregion + ' \u2014 ' + regionCountries.length + ' countries' +
    (newCount < regionCountries.length ? ' (' + newCount + ' new)' : '');

  preview.style.display = 'block';
});

document.getElementById('add-region-btn').addEventListener('click', function () {
  const errorEl = document.getElementById('region-error');
  errorEl.style.display = 'none';

  const config = getConfig();
  if (!config) {
    errorEl.textContent = 'Cannot add \u2014 underlying JSON is invalid.';
    errorEl.style.display = 'block';
    return;
  }
  if (!Array.isArray(config.destinations)) config.destinations = [];

  const checkboxes = document.querySelectorAll('#region-country-list input[type="checkbox"]:checked:not(:disabled)');
  if (checkboxes.length === 0) {
    errorEl.textContent = 'No countries selected.';
    errorEl.style.display = 'block';
    return;
  }

  let added = 0;
  checkboxes.forEach(cb => {
    const code = cb.value;
    const c = allCountries.find(x => x.code === code);
    if (!c) return;
    // Skip if this exact code already exists
    if (config.destinations.find(d => d.code === code)) return;
    config.destinations.push({
      country: c.name,
      code: c.code,
      postalCode: c.capital || '00000',
      zone: null,
      desc: c.capital || null,
    });
    added++;
  });

  setConfig(config);
  renderDestinations();

  // Reset region picker
  document.getElementById('region-select').value = '';
  document.getElementById('region-preview').style.display = 'none';

  if (added > 0) {
    errorEl.style.display = 'none';
    // Brief success feedback
    const btn = document.getElementById('add-region-btn');
    const orig = btn.textContent;
    btn.textContent = 'Added ' + added + ' countries';
    btn.disabled = true;
    setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000);
  }
});

// ---------------------------------------------------------------------------
// Add / Remove single destination
// ---------------------------------------------------------------------------

// Manual add — for the advanced entry form
function addDest() {
  const errorEl = document.getElementById('dest-add-error');
  errorEl.style.display = 'none';

  const code    = document.getElementById('new-code').value.trim().toUpperCase();
  const postal  = document.getElementById('new-postal').value.trim();
  const zoneRaw = document.getElementById('new-zone').value.trim();
  const desc    = document.getElementById('new-desc').value.trim();

  if (!code || code.length !== 2) {
    errorEl.textContent = 'Country code must be exactly 2 letters (ISO 3166-1 alpha-2).';
    errorEl.style.display = 'block';
    return;
  }

  // Look up country name and defaults from API data
  const apiCountry = allCountries.find(c => c.code === code);
  const country = apiCountry ? apiCountry.name : code;
  const finalPostal = postal || (apiCountry ? apiCountry.capital : '') || '00000';
  const finalDesc = desc || (apiCountry ? apiCountry.capital : '') || null;

  // Warn if flagged
  const flag = getFlagged(code);
  if (flag) {
    const riskLabel = RISK_LABELS[flag.risk] || flag.risk;
    if (!confirm('Warning: ' + country + ' (' + code + ') is flagged as ' + riskLabel + ' risk.\n\n' + flag.reason + '\n\nAre you sure you want to add it?')) {
      return;
    }
  }

  const config = getConfig();
  if (!config) {
    errorEl.textContent = 'Cannot add \u2014 underlying JSON is invalid. Fix it in the raw editor first.';
    errorEl.style.display = 'block';
    return;
  }
  if (!Array.isArray(config.destinations)) config.destinations = [];

  if (config.destinations.find(d => d.code === code)) {
    errorEl.textContent = country + ' (' + code + ') is already in the list.';
    errorEl.style.display = 'block';
    return;
  }

  const entry = { country, code, postalCode: finalPostal };
  entry.zone = zoneRaw !== '' ? Number(zoneRaw) : null;
  if (finalDesc) entry.desc = finalDesc;

  config.destinations.push(entry);
  setConfig(config);
  renderDestinations();

  // Clear inputs
  document.getElementById('new-code').value = '';
  document.getElementById('new-postal').value = '';
  document.getElementById('new-zone').value = '';
  document.getElementById('new-desc').value = '';
}

function removeDest(index) {
  const config = getConfig();
  if (!config || !Array.isArray(config.destinations)) return;

  const dest = config.destinations[index];
  if (!confirm('Remove ' + dest.country + ' \u2014 ' + (dest.desc || dest.postalCode) + '?')) return;

  config.destinations.splice(index, 1);
  setConfig(config);
  renderDestinations();
}

// ---------------------------------------------------------------------------
// Analysis settings
// ---------------------------------------------------------------------------

function initAnalysisSettings() {
  const config = getConfig();

  // VAT inclusive toggle
  const vatCheckbox = document.getElementById('vat-inclusive');
  if (config && config.analysis) {
    vatCheckbox.checked = config.analysis.vatInclusive !== false;
  } else {
    vatCheckbox.checked = true;
  }

  vatCheckbox.addEventListener('change', function() {
    const config = getConfig();
    if (!config) return;
    if (!config.analysis) config.analysis = {};
    config.analysis.vatInclusive = this.checked;
    setConfig(config);
  });

  // Merge threshold slider
  const slider = document.getElementById('merge-threshold');
  const output = document.getElementById('merge-threshold-value');
  if (config && config.analysis && config.analysis.intlZoneMergeThreshold != null) {
    slider.value = Math.round(config.analysis.intlZoneMergeThreshold * 100);
  }
  output.textContent = slider.value + '%';

  slider.addEventListener('input', function() {
    output.textContent = this.value + '%';
    const config = getConfig();
    if (!config) return;
    if (!config.analysis) config.analysis = {};
    config.analysis.intlZoneMergeThreshold = Number(this.value) / 100;
    setConfig(config);
  });
}

// ---------------------------------------------------------------------------
// JSON editor helpers
// ---------------------------------------------------------------------------

function formatJson() {
  const editor = document.getElementById('config-editor');
  const errorEl = document.getElementById('config-error');
  try {
    const parsed = JSON.parse(editor.value);
    editor.value = JSON.stringify(parsed, null, 2);
    errorEl.style.display = 'none';
  } catch (e) {
    errorEl.textContent = 'Invalid JSON: ' + e.message;
    errorEl.style.display = 'block';
  }
}

function syncTableFromEditor() {
  const errorEl = document.getElementById('config-error');
  const config = getConfig();
  if (!config) {
    errorEl.textContent = 'Cannot reload \u2014 JSON is invalid.';
    errorEl.style.display = 'block';
    return;
  }
  errorEl.style.display = 'none';
  renderDestinations();
  initAnalysisSettings();
}

// ---------------------------------------------------------------------------
// Form submit validation
// ---------------------------------------------------------------------------

document.getElementById('config-form').addEventListener('submit', function(e) {
  const editor = document.getElementById('config-editor');
  const errorEl = document.getElementById('config-error');
  try {
    JSON.parse(editor.value);
    errorEl.style.display = 'none';
  } catch (err) {
    e.preventDefault();
    errorEl.textContent = 'Cannot save \u2014 invalid JSON: ' + err.message;
    errorEl.style.display = 'block';
    // Open the advanced section so the user can see the error
    document.querySelector('details.mt-2').open = true;
  }
});

// ---------------------------------------------------------------------------
// Add-country tab switching
// ---------------------------------------------------------------------------

document.querySelectorAll('.add-tab').forEach(tab => {
  tab.addEventListener('click', function () {
    document.querySelectorAll('.add-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.add-panel').forEach(p => p.classList.remove('active'));
    this.classList.add('active');
    document.getElementById(this.dataset.panel).classList.add('active');
  });
});

// ---------------------------------------------------------------------------
// Bind events & initial render
// ---------------------------------------------------------------------------

document.getElementById('add-dest-btn').addEventListener('click', addDest);
renderDestinations();
initAnalysisSettings();
</script>
