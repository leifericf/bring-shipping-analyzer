<ul class="breadcrumb">
  <li><a href="/">Dashboard</a></li>
  <li><%= account.name %></li>
</ul>

<hgroup>
  <h1><%= account.name %></h1>
  <p>Customer <code><%= account.customer_number %></code> &middot; Origin <code><%= account.origin_postal_code %></code></p>
</hgroup>

<div class="actions mb-1">
  <form method="POST" action="/accounts/<%= account.id %>/runs">
    <button type="submit">Start New Run</button>
  </form>
  <a href="/accounts/<%= account.id %>/config" role="button" class="outline secondary">Config</a>
  <a href="/accounts/<%= account.id %>/edit" role="button" class="outline secondary">Edit Account</a>
</div>

<h2>Runs</h2>

<% if (runs.length === 0) { %>
  <div class="empty-state">
    <p>No runs yet.</p>
    <p>Click <strong>Start New Run</strong> to fetch rates and invoices.</p>
  </div>
<% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Run</th>
          <th>Date</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const run of runs) { %>
          <tr>
            <td><a href="/runs/<%= run.id %>">#<%= run.id %></a></td>
            <td><%= fmtDate(run.created_at) %></td>
            <td><span class="status status-<%= run.status %>"><%= run.status.replace(/_/g, ' ') %></span></td>
            <td><a href="/runs/<%= run.id %>">View</a></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } %>
